# Backend Environment Configuration

# ===========================================
# Application Settings
# ===========================================
APP_NAME=EduPlatform API
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=eduplatform
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=eduplatform_dev

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# OpenAI API Configuration
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
# Required for Voice Chat (Realtime API) and LLM features
# Tier 1+ account required (minimum $5 top-up) for Realtime API access
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Realtime API Settings (for Voice Chat)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# Voice Provider: "openai" (cloud, no GPU required) or "personaplex" (local GPU)
VOICE_PROVIDER=openai

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# CORS Settings
# ===========================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]

# ===========================================
# TTS Settings (Edge TTS - free)
# ===========================================
TTS_PROVIDER=edge
EDGE_TTS_VOICE_RU_FEMALE=ru-RU-SvetlanaNeural
EDGE_TTS_VOICE_RU_MALE=ru-RU-DmitryNeural
EDGE_TTS_VOICE_EN_FEMALE=en-US-AriaNeural
EDGE_TTS_VOICE_EN_MALE=en-US-GuyNeural

# ===========================================
# NVIDIA PersonaPlex (optional, local GPU)
# ===========================================
PERSONAPLEX_WS_URL=wss://localhost:8998

# ===========================================
# File Upload Settings
# ===========================================
MAX_FILE_SIZE=52428800

# ===========================================
# AI Model Settings
# ===========================================
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o
LLM_MODEL_MINI=gpt-4o-mini
