# EduPlatform Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_USER=eduplatform
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eduplatform_dev

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# OPENAI API KEY (Required)
# Get your key from: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# =============================================================================
# TAVILY API KEY (Optional - for web search)
# Get your key from: https://tavily.com/
# =============================================================================
TAVILY_API_KEY=tvly-YOUR_TAVILY_API_KEY_HERE

# =============================================================================
# JWT SECRETS (Generate with: openssl rand -hex 32)
# =============================================================================
SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=development
DEBUG=True

# =============================================================================
# VOICE CONFIGURATION
# =============================================================================

# Voice Provider: "openai" (cloud) or "voicebox" (local TTS)
VOICE_PROVIDER=openai

# OpenAI Realtime API Settings
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# Voicebox TTS Settings (local Qwen3-TTS)
# Voicebox backend must be running on this URL
VOICEBOX_API_URL=http://localhost:8001
# Default voice profile ID (create via Voicebox API first)
VOICEBOX_DEFAULT_PROFILE_ID=
# Default language: ru, en, de, fr, es, it, ja, ko, zh, pt
VOICEBOX_DEFAULT_LANGUAGE=en
# Model size: 1.7B (better quality) or 0.6B (faster)
VOICEBOX_MODEL_SIZE=1.7B
# Timeout for TTS generation in seconds
VOICEBOX_TIMEOUT_SECONDS=60

# =============================================================================
# SECURITY NOTES:
# 1. NEVER commit this file with real values to Git
# 2. Generate secure passwords: openssl rand -base64 32
# 3. Generate secure secrets: openssl rand -hex 32
# 4. Keep your API keys secret and rotate them regularly
# =============================================================================
